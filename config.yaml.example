# Meeting Scribe Configuration

audio:
  device: "BlackHole 2ch"
  sample_rate: 16000
  channels: 1

transcription:
  model_size: "large-v3-turbo"
  compute_type: "int8"
  cpu_threads: 4
  language: "en"
  beam_size: 5
  chunk_duration_seconds: 30
  overlap_seconds: 2

diarization:
  similarity_threshold: 0.75
  min_segment_duration: 1.0

detection:
  poll_interval_seconds: 5
  start_debounce_seconds: 3
  end_debounce_seconds: 10
  silence_timeout_seconds: 60

hotkey:
  combination: "<fn>+<f12>"

output:
  transcript_dir: "~/meeting-scribe/transcripts"
  incremental_save_seconds: 60

ui:
  auto_detect_meetings: true
  notify_on_detection: true
  auto_start_recording: false
